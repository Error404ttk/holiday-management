APP_NAME="HOSxP Holiday Management"
NODE_ENV=development
APP_ENV=development
API_PORT=3000
APP_PORT=3000
WEB_PORT=5173
FRONTEND_ORIGIN=http://localhost:5173
JWT_SECRET=change_me_to_a_long_random_secret_at_least_24_chars
JWT_EXPIRES_IN=8h

# HOSxP v3 MySQL/MariaDB read-only connection for Step 11.
DB_HOST=192.168.99.10
DB_PORT=3306
DB_USER=holiday_readonly
DB_PASSWORD=change_me
DB_NAME=hosxp

# HOSxP write user for Step 12. Must be limited to SELECT, INSERT, UPDATE on hosxp.holiday only.
DB_USER_WRITE=holiday_write
DB_PASSWORD_WRITE=change_me

# App-owned database for audit log. Do not point this at HOSxP unless audit_logs is intentionally created there.
APP_DB_HOST=192.168.99.10
APP_DB_PORT=3306
APP_DB_USER=holiday_app
APP_DB_PASSWORD=change_me
APP_DB_NAME=hosxp_holiday_app

# Confirm these with SHOW COLUMNS FROM holiday before enabling write tests.
HOLIDAY_TABLE=holiday
HOLIDAY_ID_COLUMN=
HOLIDAY_DATE_COLUMN=holiday_date
HOLIDAY_NAME_COLUMN=holiday_name
HOLIDAY_TYPE_COLUMN=
HOLIDAY_ACTIVE_COLUMN=
HOLIDAY_NOTE_COLUMN=
HOLIDAY_ACTIVE_TRUE_VALUE=1
HOLIDAY_ACTIVE_FALSE_VALUE=0
